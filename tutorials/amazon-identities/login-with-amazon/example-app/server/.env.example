# Server
PORT=3443
SESSION_SECRET=replace-with-a-strong-random-string

# Advertising API (Public OAuth)
ADS_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADS_REDIRECT_URI=https://localhost:3443/auth/advertising/callback

# Seller Central - Public App
SELLER_PUBLIC_APP_ID=amzn1.sp.solution.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SELLER_PUBLIC_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SELLER_PUBLIC_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SELLER_PUBLIC_REDIRECT_URI=https://localhost:3443/auth/seller/callback

# Vendor Central - Public App
VENDOR_PUBLIC_APP_ID=amzn1.sp.solution.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VENDOR_PUBLIC_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VENDOR_PUBLIC_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VENDOR_PUBLIC_REDIRECT_URI=https://localhost:3443/auth/vendor/callback
